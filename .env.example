# Required
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your-plex-token-here
TAUTULLI_URL=http://localhost:8181
TAUTULLI_API_KEY=your-tautulli-api-key-here
TMDB_API_TOKEN=your_read_access_token_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plex_recommender

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Choose between 'ollama' (local) or 'openrouter' (cloud)
LLM_PROVIDER=ollama

# --- Ollama (Local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_CTX=16384  # Context window size (16K is good with RAG)

# --- OpenRouter (Cloud) ---
# Get an API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CONTEXT_WINDOW=128000  # 128K context for large history/libraries

# Scheduling
SYNC_INTERVAL_MINUTES=30
RECOMMENDATION_DAY=sunday
RECOMMENDATION_HOUR=3

# Recommendations
MIN_CONFIDENCE_SCORE=0.7
MAX_RECOMMENDATIONS_PER_USER=20
LABEL_PREFIX=AI-Rec

# LLM Prompt Limits (0 = unlimited, sends everything)
MAX_LIBRARY_ITEMS=0
MAX_WATCH_HISTORY_ITEMS=0
COMPACT_PROMPT=true

# Recommendation Weights (should sum to 1.0)
## Default
WEIGHT_GENRE=0.25
WEIGHT_ACTOR=0.20
WEIGHT_KEYWORD=0.25
WEIGHT_STUDIO=0.15
WEIGHT_LANGUAGE=0.10
WEIGHT_YEAR=0.05

## “Taste‑Driven” (prioritizes actors + vibe)
### Actors + keywords drive the strongest “I’d actually watch this” signal. Genre still matters but doesn’t dominate.
# WEIGHT_GENRE=0.20
# WEIGHT_ACTOR=0.30
# WEIGHT_KEYWORD=0.30
# WEIGHT_STUDIO=0.10
# WEIGHT_LANGUAGE=0.05
# WEIGHT_YEAR=0.05

## “Discovery‑Friendly” (more variety, less actor bias)
### Genre + keywords shape the recommendation, but actor influence is softened so you don’t get stuck in loops (e.g., everything with Tom Cruise).
# WEIGHT_GENRE=0.30
# WEIGHT_ACTOR=0.15
# WEIGHT_KEYWORD=0.30
# WEIGHT_STUDIO=0.10
# WEIGHT_LANGUAGE=0.10
# WEIGHT_YEAR=0.05

## “Cinematic Feel” (emphasizes era + studio identity)
### Studio + year help cluster films with similar production values and pacing, which often improves “this feels like that” matching.
# WEIGHT_GENRE=0.20
# WEIGHT_ACTOR=0.20
# WEIGHT_KEYWORD=0.25
# WEIGHT_STUDIO=0.20
# WEIGHT_LANGUAGE=0.05
# WEIGHT_YEAR=0.10

# Batch Processing (fallback when RAG is disabled)
BATCH_PROCESSING=true
BATCH_SIZE=0   # Auto-calculate based on context window

# RAG (Retrieval-Augmented Generation) - Recommended for large libraries
USE_RAG=true                       # Use vector search to find relevant content
LANCEDB_PATH=./data/lancedb        # Path to vector database
EMBEDDINGS_MODEL=nomic-embed-text  # Ollama model for embeddings (lightweight)
RAG_TOP_K=200                      # Number of most-similar items to send to LLM